{
  "info": {
    "name": "Chai and Backend API",
    "description": "API collection for user management and video platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "apiVersion",
      "value": "api/v1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "multipart/form-data",
                "disabled": true
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "fullName",
                  "value": "John Doe",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "john.doe@example.com",
                  "type": "text"
                },
                {
                  "key": "username",
                  "value": "johndoe",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "securepassword123",
                  "type": "text"
                },
                {
                  "key": "avatar",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "coverImage",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiVersion}}/users/register",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiVersion}}", "users", "register"]
            },
            "description": "Register a new user with avatar and cover image upload"
          },
          "response": [
            {
              "name": "Success Response",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {
                      "key": "fullName",
                      "value": "John Doe",
                      "type": "text"
                    },
                    {
                      "key": "email",
                      "value": "john.doe@example.com",
                      "type": "text"
                    },
                    {
                      "key": "username",
                      "value": "johndoe",
                      "type": "text"
                    },
                    {
                      "key": "password",
                      "value": "securepassword123",
                      "type": "text"
                    }
                  ]
                },
                "url": {
                  "raw": "{{baseUrl}}/{{apiVersion}}/users/register",
                  "host": ["{{baseUrl}}"],
                  "path": ["{{apiVersion}}", "users", "register"]
                }
              },
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "cookie": [],
              "body": "{\n    \"statusCode\": 200,\n    \"data\": {\n        \"_id\": \"64f8a2b3c1d2e3f4a5b6c7d8\",\n        \"username\": \"johndoe\",\n        \"email\": \"john.doe@example.com\",\n        \"fullName\": \"John Doe\",\n        \"avatar\": \"https://cloudinary.com/avatar.jpg\",\n        \"coverImage\": \"https://cloudinary.com/cover.jpg\",\n        \"watchHistory\": [],\n        \"createdAt\": \"2023-09-06T10:30:00.000Z\",\n        \"updatedAt\": \"2023-09-06T10:30:00.000Z\"\n    },\n    \"message\": \"User registered Successfully\",\n    \"success\": true\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "API Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Check if the API is running"
          },
          "response": [
            {
              "name": "API Running",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/",
                  "host": ["{{baseUrl}}"],
                  "path": [""]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "text",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "text/html"
                }
              ],
              "cookie": [],
              "body": "Welcome to the API"
            }
          ]
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Set dynamic variables if needed",
          "// pm.environment.set('timestamp', Date.now());"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global test scripts",
          "pm.test('Response time is less than 5000ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});",
          "",
          "if (pm.response.code === 200 || pm.response.code === 201) {",
          "    pm.test('Response has success status', function () {",
          "        pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
          "    });",
          "}"
        ]
      }
    }
  ]
}
